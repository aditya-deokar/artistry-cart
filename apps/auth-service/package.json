{
  "name": "@artistry-cart/auth-service",
  "version": "0.0.1",
  "private": true,
  "nx": {
    "targets": {
      "serve": {
        "continuous": true,
        "executor": "@nx/js:node",
        "defaultConfiguration": "development",
        "dependsOn": [
          "build"
        ],
        "options": {
          "buildTarget": "@artistry-cart/auth-service:build",
          "runBuildTargetDependencies": false
        },
        "configurations": {
          "development": {
            "buildTarget": "@artistry-cart/auth-service:build:development"
          },
          "production": {
            "buildTarget": "@artistry-cart/auth-service:build:production"
          }
        }
      },
      "test": {
        "options": {
          "passWithNoTests": true
        }
      },
      "docker-build": {
        "dependsOn": [
          "build"
        ],
        "command": "docker build -f docker/backend.Dockerfile . --build-arg APP_NAME=auth-service --build-arg BUILD_OUTPUT=apps/auth-service/dist --build-arg APP_PORT=6001 -t artistry-cart-auth-service"
      }
    }
  },
  "dependencies": {
    "@artistry-cart/error-handler": "workspace:*",
    "@artistry-cart/libs": "workspace:*",
    "@artistry-cart/middleware": "workspace:*",
    "@artistry-cart/utils": "workspace:*"
  }
}
