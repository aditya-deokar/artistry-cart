{
  "name": "@artistry-cart/error-handler",
  "version": "0.0.1",
  "private": true,
  "main": "./dist/index.js",
  "types": "./index.ts",
  "exports": {
    ".": {
      "types": "./index.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./error-middelware": {
      "types": "./error-middelware.ts",
      "import": "./dist/error-middelware.js",
      "require": "./dist/error-middelware.js",
      "default": "./dist/error-middelware.js"
    }
  },
  "nx": {
    "targets": {
      "build": {
        "executor": "@nx/js:tsc",
        "outputs": [
          "{options.outputPath}"
        ],
        "options": {
          "main": "packages/error-handler/index.ts",
          "outputPath": "packages/error-handler/dist",
          "tsConfig": "packages/error-handler/tsconfig.lib.json",
          "clean": true,
          "generatePackageJson": false
        }
      }
    }
  }
}
