{
  "name": "@artistry-cart/utils",
  "version": "0.0.1",
  "private": true,
  "main": "./dist/index.js",
  "types": "./index.ts",
  "exports": {
    ".": {
      "types": "./index.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./runtime": {
      "types": "./runtime/index.ts",
      "import": "./dist/runtime/index.js",
      "require": "./dist/runtime/index.js",
      "default": "./dist/runtime/index.js"
    },
    "./kafka": {
      "types": "./kafka/index.ts",
      "import": "./dist/kafka/index.js",
      "require": "./dist/kafka/index.js",
      "default": "./dist/kafka/index.js"
    },
    "./kafka/analytics-contract": {
      "types": "./kafka/analytics-contract.ts",
      "import": "./dist/kafka/analytics-contract.js",
      "require": "./dist/kafka/analytics-contract.js",
      "default": "./dist/kafka/analytics-contract.js"
    },
    "./kafka/analytics-producer": {
      "types": "./kafka/analytics-producer.ts",
      "import": "./dist/kafka/analytics-producer.js",
      "require": "./dist/kafka/analytics-producer.js",
      "default": "./dist/kafka/analytics-producer.js"
    },
    "./kafka/client": {
      "types": "./kafka/client.ts",
      "import": "./dist/kafka/client.js",
      "require": "./dist/kafka/client.js",
      "default": "./dist/kafka/client.js"
    },
    "./kafka/admin": {
      "types": "./kafka/admin.ts",
      "import": "./dist/kafka/admin.js",
      "require": "./dist/kafka/admin.js",
      "default": "./dist/kafka/admin.js"
    },
    "./kafka/health": {
      "types": "./kafka/health.ts",
      "import": "./dist/kafka/health.js",
      "require": "./dist/kafka/health.js",
      "default": "./dist/kafka/health.js"
    }
  },
  "dependencies": {
    "tslib": "^2.3.0"
  },
  "nx": {
    "targets": {
      "build": {
        "executor": "@nx/js:tsc",
        "outputs": [
          "{options.outputPath}"
        ],
        "options": {
          "main": "packages/utils/index.ts",
          "outputPath": "packages/utils/dist",
          "tsConfig": "packages/utils/tsconfig.lib.json",
          "clean": true,
          "generatePackageJson": false
        }
      }
    }
  }
}
