{
  "name": "@artistry-cart/libs",
  "version": "0.0.1",
  "private": true,
  "main": "./dist/index.js",
  "types": "./index.ts",
  "exports": {
    ".": {
      "types": "./index.ts",
      "default": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./imageKit": {
      "types": "./imageKit/index.ts",
      "default": "./dist/imageKit/index.js",
      "require": "./dist/imageKit/index.js"
    },
    "./prisma": {
      "types": "./prisma/index.ts",
      "default": "./dist/prisma/index.js",
      "require": "./dist/prisma/index.js"
    },
    "./redis": {
      "types": "./redis/index.ts",
      "default": "./dist/redis/index.js",
      "require": "./dist/redis/index.js"
    }
  },
  "nx": {
    "targets": {
      "build": {
        "executor": "@nx/js:tsc",
        "outputs": [
          "{options.outputPath}"
        ],
        "options": {
          "main": "packages/libs/index.ts",
          "outputPath": "packages/libs/dist",
          "tsConfig": "packages/libs/tsconfig.lib.json",
          "clean": true,
          "generatePackageJson": false
        }
      }
    }
  }
}
