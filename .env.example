# Copy this file to `.env` and adjust values as needed.
# Runtime / networking
HOST="0.0.0.0"
CORS_ALLOWED_ORIGINS="http://localhost:3000,http://localhost:3001"

# Frontend runtime
NEXT_PUBLIC_SERVER_URI="http://localhost:8080"
INTERNAL_SERVER_URI="http://localhost:8080"
NEXT_PUBLIC_FRONTEND_URL="http://localhost:3000"
NEXT_PUBLIC_USER_UI_LINK="http://localhost:3000"
NEXT_PUBLIC_AI_VISION_API_URL="http://localhost:8080/ai-vision/api/v1/ai"

# Prisma / MongoDB
DATABASE_URL="mongodb://localhost:27017/artistry-cart"

# Internal service URLs for api-gateway and containerized environments
AUTH_SERVICE_URL="http://localhost:6001"
PRODUCT_SERVICE_URL="http://localhost:6002"
ORDER_SERVICE_URL="http://localhost:6004"
RECOMMENDATION_SERVICE_URL="http://localhost:6005"
AIVISION_SERVICE_URL="http://localhost:6006"

# Kafka configuration
KAFKA_BROKERS="localhost:9092"
KAFKA_CLIENT_ID="kafka-service"
KAFKA_SSL="false"
KAFKA_SASL_USERNAME=""
KAFKA_SASL_PASSWORD=""
KAFKA_SASL_MECHANISM="plain"
KAFKA_CONSUMER_GROUP_ID="user-events-group"
KAFKA_USER_EVENTS_TOPIC="users-events"
KAFKA_CONSUMER_BATCH_INTERVAL_MS="3000"

# OAuth Configuration
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
FACEBOOK_CLIENT_ID=""
FACEBOOK_CLIENT_SECRET=""
OAUTH_REDIRECT_BASE_URL="http://localhost:6001"
FRONTEND_URL="http://localhost:3000"

# JWT Secrets
ACCESS_TOKEN_SECRET=""
REFRESH_TOKEN_SECRET=""

# Payments
STRIPE_SECRETE_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLIC_KEY=""

# Redis (set REDIS_ENABLED=false to disable)
REDIS_ENABLED="true"
REDIS_URL="redis://localhost:6379"

# AI Vision
GOOGLE_API_KEY=""
HUGGINGFACE_API_KEY=""
IMAGEKIT_PUBLIC_API_KEY=""
IMAGEKIT_PRIVATE_API_KEY=""
IMAGEKIT_URL_ENDPOINT=""
